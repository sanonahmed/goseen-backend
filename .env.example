# ─── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── PostgreSQL (Neon or Railway) ──────────────────────────────────────────────
# Neon:    postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/goseen?sslmode=require
# Railway: postgresql://postgres:pass@containers-us-west-xxx.railway.app:5432/railway
DATABASE_URL=postgresql://postgres:password@localhost:5432/goseen

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_me_access_secret_64_chars_min
JWT_REFRESH_SECRET=change_me_refresh_secret_64_chars_min
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ─── Email (OTP) ───────────────────────────────────────────────────────────────
# Use Gmail app password, Resend, or any SMTP provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=GoSeen <noreply@goseen.app>

# ─── Cloudflare R2 ─────────────────────────────────────────────────────────────
# Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=goseen-media
# Custom domain bound to your R2 bucket (or use r2.dev subdomain)
R2_PUBLIC_URL=https://media.goseen.app

# ─── Firebase (push notifications) ────────────────────────────────────────────
# 1. Go to Firebase Console → Project Settings → Service Accounts
# 2. Click "Generate new private key" → download JSON
# 3. Minify to one line: node -e "const f=require('./serviceAccount.json'); console.log(JSON.stringify(f))"
# 4. Set as env var on Railway (paste the one-line JSON string)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"wegrapher-5c82b",...}

# ─── App ───────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
